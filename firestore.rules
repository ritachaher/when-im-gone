rules_version = '2';

// The vault collection stores AES-GCM-256 encrypted blobs, one document
// per authenticated user. Each document is keyed by the caller's
// anonymous Firebase Auth UID — read and write are permitted only if
// the caller owns that UID. No plaintext ever touches Firestore.
//
// Write-size is capped at ~1 MB (Firestore's hard limit) so a
// compromised client can't run up quota.
service cloud.firestore {
  match /databases/{database}/documents {
    match /vaults/{uid} {
      allow read: if request.auth != null
                  && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.keys().hasAll(['data', 'updatedAt'])
                   && request.resource.data.data is string
                   && request.resource.data.data.size() < 1000000;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
