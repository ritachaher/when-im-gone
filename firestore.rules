rules_version = '2';

// Users can only read/write their own backup document. Data stored here is an
// encrypted blob — the server still enforces ownership so one user cannot read
// another user's ciphertext (which would leak metadata like file size).
service cloud.firestore {
  match /databases/{database}/documents {
    match /backups/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
