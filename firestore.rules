rules_version = '2';

// The vault collection stores AES-GCM-256 encrypted blobs. Each
// document is keyed by SHA-256 of the user's recovery code (see
// crypto/deriveVaultCloudId), which is ~60 bits of entropy — too
// expensive to enumerate. Every device that holds the recovery code
// computes the same ID, so phone and PC land on the same document.
//
// Access control: anyone holding the recovery code can already decrypt
// the contents, so "you need the recovery code to find the document"
// is exactly the right level of gating. We still require Firebase Auth
// (anonymous is fine) so Firestore has a per-client rate-limit anchor
// against drive-by spam. The 1 MB write cap blocks quota-exhaustion
// attacks from a compromised client.
service cloud.firestore {
  match /databases/{database}/documents {
    match /vaults/{vaultId} {
      allow read: if request.auth != null
                  && vaultId.matches('^[0-9a-f]{64}$');
      allow write: if request.auth != null
                   && vaultId.matches('^[0-9a-f]{64}$')
                   && request.resource.data.keys().hasAll(['data', 'updatedAt'])
                   && request.resource.data.data is string
                   && request.resource.data.data.size() < 1000000;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
